# Multi-Agent Workflow System - Environment Variables Template
# Copy this file to .env and fill in your actual credentials
# IMPORTANT: Never commit .env file to version control

# ============================================================
# FREE AI CONTENT GENERATION (Google Gemini)
# ============================================================
# Get FREE API key from: https://makersuite.google.com/app/apikey
# Completely FREE for demos and development!
GEMINI_API_KEY=your_gemini_api_key_here

# Brand voice settings
BRAND_TONE=professional_friendly
BRAND_VOICE=innovative_approachable

# ============================================================
# GMAIL API CREDENTIALS
# ============================================================
# Get credentials from: https://console.cloud.google.com/
# Enable Gmail API and create OAuth 2.0 credentials
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here

# ============================================================
# LINKEDIN CREDENTIALS
# ============================================================
# For browser automation (recommended)
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password_here

# For API access (optional)
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here

# ============================================================
# X (TWITTER) API CREDENTIALS
# ============================================================
# Get credentials from: https://developer.twitter.com/en/portal/dashboard
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here
X_BEARER_TOKEN=your_x_bearer_token_here

# ============================================================
# FACEBOOK API CREDENTIALS
# ============================================================
# Get credentials from: https://developers.facebook.com/apps/
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here

# ============================================================
# INSTAGRAM API CREDENTIALS
# ============================================================
# Instagram uses Facebook Graph API
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here

# ============================================================
# WHATSAPP CONFIGURATION
# ============================================================
# Get credentials from: https://developers.facebook.com/apps/
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here

# ============================================================
# ODOO ERP CREDENTIALS
# ============================================================
# Get from your Odoo instance
ODOO_URL=https://your-instance.odoo.com
ODOO_DB=your_database_name
ODOO_USERNAME=your_odoo_email@example.com
ODOO_PASSWORD=your_odoo_password_here

# ============================================================
# WORKFLOW CONFIGURATION
# ============================================================
INBOX_PATH=Inbox
NEEDS_ACTION_PATH=Needs_Action
PENDING_APPROVAL_PATH=Pending_Approval
APPROVED_PATH=Approved
DONE_PATH=Done
LOGS_PATH=logs

# ============================================================
# SYSTEM SETTINGS
# ============================================================
# Check intervals (in seconds)
GMAIL_CHECK_INTERVAL=1800
LINKEDIN_CHECK_INTERVAL=600
X_CHECK_INTERVAL=600
FACEBOOK_CHECK_INTERVAL=600
INSTAGRAM_CHECK_INTERVAL=600
WHATSAPP_CHECK_INTERVAL=600
ODOO_CHECK_INTERVAL=1800

# Priority keywords (comma-separated)
WHATSAPP_PRIORITY_KEYWORDS=urgent,asap,invoice,payment,help,lead,meeting,deadline,important,critical,client,opportunity,partnership,collaboration,project,interested,discuss

# Dashboard settings
DASHBOARD_AUDIT_DAYS=2
VAULT_PATH=.

# ============================================================
# MCP SERVER CONFIGURATION
# ============================================================
MCP_CONFIG_PATH=.claude/mcp_config.json
